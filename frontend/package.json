    "@types/leaflet-freedraw": "^2.13.8",
    "@types/react-beautiful-dnd": "^13.1.8",
    "axios": "^1.5.0",
    "d3": "^7.8.5",
    "fabric": "^5.3.0",
    "leaflet": "^1.9.4",
    "leaflet-freedraw": "^2.15.0",
    "leaflet.heat": "^0.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
